# sontocodemo — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to git.

# --- Runtime -----------------------------------------------------------
NODE_ENV=development
PORT=8080

# --- Site --------------------------------------------------------------
SITE_URL=https://sontocodemo.sharrief.com
# Update your local .env to match — email links and redirects use this value at runtime.
SITE_NAME=Sontoco Holdings
SITE_HOST=localhost
SITE_HOST_2=
SITE_FILE_HOST=

# --- Session -----------------------------------------------------------
COOKIE_SECRET=change-me-to-a-long-random-string
SESSION_NAME=sontoco.sid

# --- Database ----------------------------------------------------------
# DB_SERVER selects the SSL cert profile used by the app:
#   azure         -- Azure MySQL with Azure SSL cert (src/server/lib/certs/azureMySQLServer)
#   digitalocean  -- DigitalOcean MySQL with DO SSL cert (src/server/lib/certs/ca-certificate)
#   dreamhost     -- DreamHost MySQL (custom cert)
#   localdreamhost -- Local Docker MySQL with NO SSL (use this for local development)
DB_SERVER=localdreamhost
DB_HOST=db
DB_PORT=3306
DB_NAME=sontocodb
DB_USER=sontoco
DB_PASSWORD=change-me-db-password
DB_ROOT_PASSWORD=change-me-root-password
DB_PASSWORD_SALT=change-me-password-salt
DB_PASSWORD_2FA_SALT=change-me-2fa-salt

# --- Email (SMTP) ------------------------------------------------------
EMAIL_SERVER=smtp.office365.com
EMAIL_PORT=587
EMAIL_USER=your-email@domain.com
EMAIL_PASS=your-smtp-password
EMAIL_FROM=no-reply@domain.com
EMAIL_REPLY_TO=support@domain.com
EMAIL_ADMIN=admin@domain.com
# Non-production only: all outbound emails redirect to these addresses
EMAIL_DEV=dev@domain.com
EMAIL_TEST_CLIENT=test-client@domain.com

# --- Feature Flags -----------------------------------------------------
SEND_REQUEST_EMAILS=false
NEW_REQUESTS_DISABLED=false

# --- Observability -----------------------------------------------------
# Azure Application Insights -- leave blank to disable telemetry
APPINSIGHTS_INSTRUMENTATIONKEY=

# --- Client Build (optional) -------------------------------------------
WATCH_CLIENT=

# --- Docker Compose ----------------------------------------------------
# Used by docker-compose.dev.yml to name the project
COMPOSE_PROJECT_NAME=sontocodemo
